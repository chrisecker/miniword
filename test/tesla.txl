[basestyles]
"h1" = {bold, font_size=20.0, name="Überschrift 1", role="h1", size=20, space_before=28.35}
"h2" = {bold, name="Überschrift 2", role="h2", size=16, space_before=28.35}
"list_p" = {name="Listenabsatz", paragraph_type="list", size=11}
"emp" = {name="Hervorhebung", role="italic"}
"date" = {color="#555555", name="Datum"}

[blobs]
"teslasmall.jpg" = ""

[document]
T('Nikola Tesla: Der Magier der Elektrizität')
NL({base="h1", space_after=45.35433070866142, space_before=28.34645669291339})
IMG('teslasmall.jpg', {scale_x=0.4440698176435517, scale_y=0.4440698176435517})
NL({alignment="center"})
T('Nikola Tesla (')
T('1856–1943', {color="#555555"})
T(') war ein serbisch-amerikanischer Erfinder, Physiker und Elektroingenieur, dessen Arbeit die Grundlage für unsere moderne Stromversorgung legte. Er gilt als einer der brillantesten, aber auch exzentrischsten Köpfe der Wissenschaftsgeschichte.', {italic})
NL
T('Wichtige Errungenschaften')
NL({base="h2"})
T('Tesla ist vor allem für seine Beiträge zur Entwicklung des ')
T('Wechselstroms (AC)', {bold})
T(' bekannt. Im Gegensatz zum Gleichstrom von Thomas Edison ermöglichte Teslas System den effizienten Transport von Energie über weite Strecken.')
NL
T('Seine wichtigsten Patente und Innovationen umfassen:')
NL
T('Der Induktionsmotor und das polyphase System.')
NL({base="list_p", indent=1})
T('Die Tesla-Spule zur Erzeugung von Hochfrequenz-Wechselstrom.')
NL({base="list_p", indent=1})
T('Frühe Experimente mit Radiowellen und Fernsteuerungen.')
NL({base="list_p", indent=1})
T('Visionen der drahtlosen Energieübertragung (Wardenclyffe Tower).')
NL({base="list_p", indent=1})
T('Wichtige Erfindungen')
NL({base="h2"})
T('Im Laufe seines Lebens meldete Tesla über 300 Patente an. Die bedeutendsten Erfindungen im Überblick:')
NL
T('Wechselstrom-Generator (1887): Grundlage der weltweiten Stromversorgung.')
NL({base="list_p", indent=1})
T('Induktionsmotor (1888): Ermöglichte den Antrieb von Maschinen ohne Kohlebürsten.')
NL({base="list_p", indent=1})
T('Tesla-Transformator / Tesla-Spule (1891): Erzeugt Hochspannungs-Hochfrequenzstrom.')
NL({base="list_p", indent=1})
T('Ferngesteuertes Boot (1898): Eines der ersten funkgesteuerten Fahrzeuge der Geschichte.')
NL({base="list_p", indent=1})
T('Neonbeleuchtung und Leuchtstoffröhren: Tesla demonstrierte drahtlos betriebene Leuchten.')
NL({base="list_p", indent=1})
T('Wardenclyffe-Turm (1901–1917): Geplante Station zur weltweiten drahtlosen Energieübertragung.')
NL({base="list_p", indent=1})
T('Der Stromkrieg')
NL({base="h2"})
T('In den späten 1880er Jahren lieferte sich Tesla, unterstützt von George Westinghouse, einen erbitterten Wettbewerb mit Thomas Edison. Dieser sogenannte ')
T('„War of Currents“', {bold})
T(' entschied darüber, welcher Standard die Welt elektrifizieren würde. Tesla siegte letztlich, da Wechselstrom mittels Transformatoren hoch- und runtergespannt werden konnte, was enorme technische Vorteile bot.')
NL
T('Tesla verstarb verarmt in New York, doch sein Erbe lebt in jeder Steckdose und jedem Elektromotor weiter.')
NL
ENDMARK
