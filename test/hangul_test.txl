[basestyles]
"style0" = {bold, font_size=20.0, name="Heading 1"}

[document]
T('문서토론')
NL({base="style0"})
NL
T('백악관(白堊館, 영어: White House 화이트 하우스[*])은 미국 워싱턴 D.C. 펜실베이니아 거리 NW에 위치한 미합중국 대통령의 집무실 겸 관저이다. 1800년 제2대 존 애덤스 대통령 이후로 미합중국 대통령의 주거지로 이용되어 왔으며, 집무·외국사절 접견·일상생활 등 모든 일을 여기서 한다.')
NL
NL
T("'백악관'이라는 명칭은 미국 대통령과 행정관, 최고 보좌관들의 행위 및 입장을 일컫는 환유 표현으로 사용되기도 한다. 백악관 부동산은 미국 국립 공원국이 소유한 국립 유적지와 대통령 공원의 일부이다. 2007년, 백악관은 미국인들이 가장 선호하는 건축물 목록 중, 미국 건축 기관으로 두 번째 자리를 차지했다. 백악관의 모습은 미국 20달러 지폐의 뒷면에 그려져 있다. 2016년 5월 입구 검문소에서 총격사건이 일어나 일대가 폐쇄조치가 된 사건이 있었다.[1]")
NL
NL
T('구성')
NL({base="style0"})
T('오늘날, 백악관 단지는 아래와 같이 구성되어 있다.')
NL({paragraph_type="list"})
T('중역거주지(Executive Residence)')
NL({paragraph_type="list"})
T('웨스트윙')
NL({paragraph_type="list"})
T('이스트윙')
NL({paragraph_type="list"})
T('아이젠하워 행정동 빌딩(Eisenhower Executive Office Building, 이전 국무부 건 로 현재는 대통령 보좌관과 부통령의 집무실로 이용된다.)')
NL({paragraph_type="list"})
T('블레어 하우스(Blair House, 객청)')
NL({paragraph_type="list"})
NL
T('중역거주지(Executive Residence)는 6층 건물로 구성되어 있으며, 1층 그라운드 층과 스테이트 층, 2층, 3층, 그리고 지하 2층으로 구성되어 있다.')
ENDMARK
